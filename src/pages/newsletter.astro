---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Newsletter - A Pura Leña">
  <section class="min-h-screen bg-gradient-to-b from-zinc-950 to-zinc-900 py-24 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-16">
        <span class="text-orange-500 text-sm font-semibold tracking-widest uppercase">Boletín</span>
        <h1 class="text-4xl md:text-5xl font-bold text-white mt-4 mb-6">
          Newsletter
        </h1>
        <p class="text-white/70 text-lg max-w-2xl mx-auto">
          Recibí las últimas novedades, promociones y recetas de asado directamente en tu email.
        </p>
      </div>

      <div class="bg-white/5 border border-white/10 rounded-2xl p-8 md:p-12 text-center">
        <div class="w-20 h-20 bg-orange-600/20 rounded-full flex items-center justify-center mx-auto mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
        </div>
        
        <h2 class="text-2xl font-semibold text-white mb-4">Próximo boletín pronto</h2>
        
        <p class="text-white/70 mb-8">
          Enterate de todas nuestras novedades y promociones exclusivas.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a 
            href="/#contacto" 
            class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-orange-600 hover:bg-orange-500 text-white font-medium rounded-lg transition-colors"
          >
            Contactános
          </a>
          <a 
            href="/" 
            class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-white/10 hover:bg-white/20 text-white font-medium rounded-lg transition-colors"
          >
            Volver al inicio
          </a>
        </div>
      </div>

      <div class="mt-12 text-center">
        <p class="text-white/70 text-sm">
          ¿Ya te suscribiste? <a href="/" class="text-orange-500 hover:underline">Volver al inicio</a>
        </p>
      </div>
    </div>
  </section>
</Layout>
