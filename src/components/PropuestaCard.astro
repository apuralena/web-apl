---
interface Props {
  titulo: string;
  descripcion: string;
  imageUrl: string;
  incluye: string[];
  index?: number;
}

const { titulo, descripcion, imageUrl, incluye, index = 0 } = Astro.props;
const reversed = index % 2 !== 0;
---

<article
  class:list={[
    "group flex flex-col md:flex-row rounded-xl border border-white/10 bg-white/3 backdrop-blur-sm overflow-hidden hover:border-orange-500/30 hover:bg-white/6 transition-all duration-300",
    reversed && "md:flex-row-reverse",
  ]}
>
  <div class='h-52 md:h-auto md:w-80 shrink-0 overflow-hidden'>
    <img
      src={imageUrl}
      alt={titulo}
      class='w-full h-full object-cover transition-transform duration-500 group-hover:scale-105'
      loading='lazy'
      decoding='async'
    />
  </div>

  <div class='p-6 grow flex flex-col'>
    <h3 class='text-lg font-semibold text-white mb-1'>
      {titulo}
    </h3>
    <p class='text-sm text-white/70 mb-5 leading-relaxed'>{descripcion}</p>

    {
      incluye && incluye.length > 0 && (
        <div class='mb-6 grow'>
          <p class='text-xs font-semibold tracking-widest uppercase text-orange-500/80 mb-3'>
            Incluye
          </p>
          <ul class='space-y-2'>
            {incluye.map((punto) => (
              <li class='flex items-center gap-2 text-sm text-white/70'>
                <svg
                  xmlns='http://www.w3.org/2000/svg'
                  width='14'
                  height='14'
                  viewBox='0 0 24 24'
                  fill='none'
                  stroke='currentColor'
                  stroke-width='2'
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  class='text-orange-500 shrink-0'
                >
                  <path d='M20 6 9 17l-5-5' />
                </svg>
                {punto}
              </li>
            ))}
          </ul>
        </div>
      )
    }

    <a
      href='/presupuesto'
      rel='noopener noreferrer'
      class='inline-flex items-center justify-center gap-2 w-full bg-orange-600 hover:bg-orange-500 text-white font-semibold py-3 px-4 rounded-lg transition-all duration-300 text-sm'
    >
      Pedir presupuesto
      <svg
        xmlns='http://www.w3.org/2000/svg'
        width='16'
        height='16'
        viewBox='0 0 24 24'
        fill='none'
        stroke='currentColor'
        stroke-width='2'
        stroke-linecap='round'
        stroke-linejoin='round'
        ><path d='M5 12h14'></path><path d='m12 5 7 7-7 7'></path></svg
      >
    </a>
  </div>
</article>
