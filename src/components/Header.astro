---
import ButtonNav from "./ButtonNav.astro";
import Nav from "./Nav.astro";
import HamburgerMenu from "./HamburgerMenu";
import Logo from "./Logo.astro";
---

<header
  class='text-white sticky top-0 z-50 bg-black/80 backdrop-blur-xl border-b border-white/5'
  style={{ position: "sticky", top: 0, zIndex: 50, width: "100%" }}
>
  <div class='max-w-7xl mx-auto px-4 py-3 flex items-center justify-between w-full'>
    <Logo />
    <Nav />
    <span class='md:hidden'>
      <HamburgerMenu client:load />
    </span>
  </div>
</header>
