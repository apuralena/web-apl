---
import Section from "../Section.astro";
import InstagramFeed from "../InstagramFeed";
import PhotoGallery from "../PhotoGallery";
import { sanityClient } from "sanity:client";

// Galería de fotos desde Sanity
const galeriaData = await sanityClient.fetch(`*[_type == "galeria"][0]{
  titulo,
  fotos[]{
    alt,
    asset->{
      url
    }
  }
}`);

const fotos =
  galeriaData?.fotos?.map((f: any) => ({
    url: f.asset?.url,
    alt: f.alt,
  })) || [];

// YouTube: último video del canal via RSS feed
const YOUTUBE_CHANNEL_ID = import.meta.env.YOUTUBE_CHANNEL_ID;
let latestVideoId: string | null = null;

try {
  const res = await fetch(
    `https://www.youtube.com/feeds/videos.xml?channel_id=${YOUTUBE_CHANNEL_ID}`,
  );
  const xml = await res.text();
  const match = xml.match(/<yt:videoId>([^<]+)<\/yt:videoId>/);
  if (match) latestVideoId = match[1];
} catch (e) {
  console.error("Error fetching YouTube feed:", e);
}
---

<Section id='experiencias'>
  <div class='space-y-4 mb-12'>
    <p class='text-sm font-medium tracking-[0.3em] uppercase text-orange-500'>
      Galería
    </p>
    <h2 class='text-4xl md:text-5xl font-bold tracking-tight text-white'>
      Experiencias
    </h2>
    <p class='text-white/40 text-lg leading-relaxed max-w-2xl'>
      Descubrí nuestras experiencias únicas y personalizadas, diseñadas para
      brindarte momentos inolvidables. Desde cenas íntimas hasta eventos
      temáticos llenos de sabor y diversión.
    </p>
  </div>

  <!-- Feed de Instagram -->
  <InstagramFeed client:visible />

  <!-- Último video de YouTube -->
  {
    latestVideoId && (
      <div class='mt-16 space-y-6'>
        <div class='space-y-2'>
          <p class='text-sm font-medium tracking-[0.3em] uppercase text-orange-500'>
            YouTube
          </p>
          <h3 class='text-2xl md:text-3xl font-bold tracking-tight text-white'>
            Último Video
          </h3>
        </div>
        <div class='rounded-2xl overflow-hidden border border-white/10 bg-black/20 backdrop-blur-sm aspect-video max-w-4xl'>
          <iframe
            src={`https://www.youtube.com/embed/${latestVideoId}`}
            title='Último video de A Pura Leña'
            allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture'
            allowfullscreen
            class='w-full h-full'
            loading='lazy'
          />
        </div>
      </div>
    )
  }

  <!-- Galería de Fotos -->
  {
    fotos.length > 0 && (
      <div class='mt-16 space-y-6'>
        <div class='space-y-2'>
          <p class='text-sm font-medium tracking-[0.3em] uppercase text-orange-500'>
            Portfolio
          </p>
          <h3 class='text-2xl md:text-3xl font-bold tracking-tight text-white'>
            Galería de Fotos
          </h3>
        </div>
        <PhotoGallery fotos={fotos} client:visible />
      </div>
    )
  }
</Section>
