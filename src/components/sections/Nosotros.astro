---
import Section from "../Section.astro";
import { sanityClient } from "sanity:client";

// Obtener TODOS los documentos de tipo "nosotros"
const nosotrosData = await sanityClient.fetch(`*[_type == "nosotros"] | order(_createdAt asc) {
  titulo,
  subtitulo,
  descripcion,
  imagen {
    asset-> {
      url
    }
  }
}`);

const items = nosotrosData || [];
---

<Section id='nosotros'>
  {items.map((item, index) => {
    const isEven = index % 2 === 0;
    const imgUrl = item.imagen?.asset?.url;
    
    return (
      <div class={`grid md:grid-cols-2 gap-16 items-center ${index > 0 ? 'mt-24' : ''}`}>
        {/* Texto - alterna posición */}
        <div class={`space-y-6 ${isEven ? '' : 'md:order-2'}`}>
          <div class='space-y-4'>
            {item.subtitulo && (
              <p class='text-sm font-medium tracking-[0.3em] uppercase text-orange-500'>
                {item.subtitulo}
              </p>
            )}
            <h2 class='text-4xl md:text-5xl font-bold tracking-tight text-white'>
              {item.titulo}
            </h2>
          </div>
          <p class='text-white/40 leading-relaxed'>
            {item.descripcion}
          </p>
        </div>
        
        {/* Imagen - alterna posición */}
        <div class={`rounded-xl overflow-hidden border border-white/10 ${isEven ? '' : 'md:order-1'}`}>
          {imgUrl && (
            <img
              src={`${imgUrl}?w=1200&q=80&auto=format`}
              alt={item.titulo || ''}
              class='w-full h-auto object-cover'
              loading='lazy'
            />
          )}
        </div>
      </div>
    );
  })}
  
  {items.length === 0 && (
    <div class='text-center text-white/40'>
      No hay contenido para la sección Nosotros.
    </div>
  )}
</Section>
