---
import { ClientRouter } from "astro:transitions";
import Footer from "../components/Footer";
import Header from "../components/Header.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";
import { StickyBanner } from "@/components/ui/sticky-banner";
import { AuroraBackground } from "../components/ui/aurora-background";
import { Toaster } from "sonner";
import { sanityClient } from "sanity:client";
import "../styles/global.css";
interface Props {
  title: string;
}
const { title } = Astro.props;

const resenas =
  (await sanityClient.fetch(`*[_type == "resena"] | order(_createdAt desc) [0...6]{
  autor,
  texto,
  estrellas,
  fecha
}`)) || [];
---

<!doctype html>
<html lang='es'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width' />
    <link rel='icon' type='image/svg+xml' href='/favicon.svg' />
    <!-- Google Site Verification: Agregar el código de GSC aquí -->
    <link rel='preconnect' href='https://fonts.googleapis.com' />
    <link rel='preconnect' href='https://fonts.gstatic.com' crossorigin />
    <link rel='preconnect' href='https://cdn.sanity.io' />
    <link rel='preconnect' href='https://i.ytimg.com' />
    <link
      href='https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap'
      rel='stylesheet'
    />
    <style is:global>
      @font-face {
        font-family: 'Space Grotesk';
        font-display: swap;
      }
      @font-face {
        font-family: 'Inter';
        font-display: swap;
      }
    </style>
    <meta name='generator' content={Astro.generator} />
    <title>{title} | A Pura Leña - Catering de Asado en Buenos Aires</title>
    <meta name='description' content='A Pura Leña - Catering de asado argentino para eventos sociales, corporativos, casamientos y eventos masivos en CABA y GBA. Carne de primera, servicio completo a leña.' />
    <link rel='canonical' href='https://apuraleña.com.ar/' />
    
    <!-- OpenGraph -->
    <meta property='og:title' content={`${title} | A Pura Leña - Catering de Asado`} />
    <meta property='og:description' content='Catering de asado argentino para eventos en Buenos Aires. Carnes de primera, servicio completo a leña, experiencia auténtica.' />
    <meta property='og:type' content='website' />
    <meta property='og:url' content='https://apuraleña.com.ar/' />
    <meta property='og:site_name' content='A Pura Leña' />
    <meta property='og:locale' content='es_AR' />
    <meta property='og:image' content='https://apuraleña.com.ar/og-image.png' />
    <meta property='og:image:width' content='1200' />
    <meta property='og:image:height' content='630' />
    
    <!-- Twitter Card -->
    <meta name='twitter:card' content='summary_large_image' />
    <meta name='twitter:title' content={`${title} | A Pura Leña`} />
    <meta name='twitter:description' content='Catering de asado argentino para eventos en CABA y GBA. Servicio completo a leña.' />
    <meta name='twitter:image' content='https://apuraleña.com.ar/og-image.png' />
    
    <!-- Schema.org -->
    <script type='application/ld+json'>
      {
        "@context": "https://schema.org",
        "@type": "CateringService",
        "name": "A Pura Leña",
        "description": "Catering de asado argentino para eventos sociales, corporativos, casamientos y eventos masivos",
        "url": "https://apuraleña.com.ar",
        "telephone": "+5491139240988",
        "email": "apuralena9@gmail.com",
        "areaServed": {
          "@type": "State",
          "name": "Ciudad Autónoma de Buenos Aires"
        },
        "areaServed": {
          "@type": "State",
          "name": "Buenos Aires"
        },
        "priceRange": "$$$",
        "openingHours": "Mo-Fr 09:00-20:00",
        "image": "https://apuraleña.com.ar/og-image.png",
        "sameAs": [
          "https://www.instagram.com/a_pura_lena/",
          "https://www.facebook.com/profile.php?id=61561940952103",
          "https://www.youtube.com/@apuraleña"
        ]
      }
    </script>
    <ClientRouter />
  </head>
  <body>
    <div class='aurora-wrapper' transition:persist='aurora-bg'>
      <AuroraBackground client:load />
    </div>
    <div class='content-wrapper'>
      <Header />
      <slot />
      <Footer resenas={resenas} client:visible />
    </div>
    <Toaster client:load richColors position='top-right' />
    <WhatsAppButton />
  </body>
</html>

<style>
  html {
    background-color: var(--background);
    margin: 0;
    padding: 0;
    margin: 0;
    width: 100%;
    scroll-behavior: smooth;
  }

  body {
    background-color: transparent;
    margin: 0;
    width: 100%;
    overflow-x: hidden;
  }

  .aurora-wrapper {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .content-wrapper {
    position: relative;
    z-index: 1;
    min-height: 100vh;
  }
</style>
