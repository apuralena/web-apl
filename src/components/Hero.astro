---
import { sanityClient } from "sanity:client";

// Traemos el primer documento de tipo hero
const hero = await sanityClient.fetch(`*[_type == "hero"][0]{
  tituloPrincipal,
  subtitulo,
  textoBotonPrincipal,
  textoBotonSecundario,
  textoDebajoCTA,
}`);

// Si no hay datos, mostramos valores por defecto para que no explote
const data = hero || {
  tituloPrincipal: "A Pura Leña",
  subtitulo: "Cargando contenido...",
  textoBotonPrincipal: "Contacto",
  textoBotonSecundario: "Ver más",
  textoDebajoCTA:
    "El mejor asado argentino en tu evento. Fuego, tradición y sabor.",
};
---

<section
  id='inicio'
  class='flex justify-center items-center min-h-[90vh] px-6 pt-20 scroll-mt-24'
>
  <div class='relative z-10 max-w-5xl w-full'>
    <div class='space-y-8'>
      <div class='space-y-2'>
        <p
          class='text-sm md:text-base font-medium tracking-[0.3em] uppercase text-orange-500'
        >
          {data.subtitulo}
        </p>
        <h1
          class='text-5xl md:text-7xl lg:text-8xl font-bold tracking-tight leading-[0.9] text-white'
        >
          {data.tituloPrincipal}
        </h1>
        <h2 class='text-2xl md:text-3xl font-light text-white/70'>
          Catering de asado argentino en Buenos Aires
        </h2>
      </div>
      <div class='flex flex-col sm:flex-row gap-4'>
        <a
          href='/presupuesto'
          class='group inline-flex items-center justify-center gap-2 bg-orange-600 hover:bg-orange-500 text-white font-semibold py-4 px-8 rounded-lg transition-all duration-300'
        >
          {data.textoBotonPrincipal}
          <svg
            xmlns='http://www.w3.org/2000/svg'
            width='18'
            height='18'
            viewBox='0 0 24 24'
            fill='none'
            stroke='currentColor'
            stroke-width='2'
            stroke-linecap='round'
            stroke-linejoin='round'
            class='transition-transform group-hover:translate-x-1'
            ><path d='M5 12h14'></path><path d='m12 5 7 7-7 7'></path></svg
          >
        </a>
        <a
          href='/#propuestas'
          class='inline-flex items-center justify-center gap-2 border border-white/20 hover:border-white/40 hover:bg-white/5 text-white font-semibold py-4 px-8 rounded-lg transition-all duration-300'
        >
          {data.textoBotonSecundario}
        </a>
      </div>
      <p
        class='text-lg md:text-xl text-white/50 w-full font-light leading-relaxed'
      >
        {data.textoDebajoCTA}
      </p>
    </div>
  </div>
</section>
